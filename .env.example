# T3MP3ST environment — copy to `.env` and fill in. NEVER commit your real .env.
# At least one LLM provider key is required (OpenRouter is the default backbone).

# ── LLM providers (set the one(s) you use) ──
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VENICE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NVIDIA NIM (OpenAI-compatible; free keys at https://build.nvidia.com/)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=
TOGETHER_API_KEY=
HUGGINGFACE_TOKEN=
REPLICATE_API_TOKEN=

# ── Custom / local OpenAI-compatible server (vLLM, llama.cpp, LM Studio…) ──
# Set LLM_PROVIDER=custom to use it. Key optional for keyless local servers.
# CUSTOM_BASE_URL=http://localhost:8080/v1   (include /v1)
# CUSTOM_MODEL=your-local-model              (or discover via the UI/CLI)
# CUSTOM_API_KEY=

# ── GitHub (xbow-bench challenge fetch / gh operations) ──
GITHUB_TOKEN=

# ── optional: default backbone overrides ──
# LLM_PROVIDER=openrouter   (openrouter | venice | anthropic | openai | nvidia | custom)
# LLM_MODEL=claude-opus-4-8
# Point any provider at a local/proxy endpoint:
# OPENROUTER_BASE_URL=  VENICE_BASE_URL=  ANTHROPIC_BASE_URL=  OPENAI_API_BASE=  NVIDIA_BASE_URL=

# Optional: Venice uncensored inference (OpenAI-compatible). https://venice.ai
VENICE_API_KEY=
